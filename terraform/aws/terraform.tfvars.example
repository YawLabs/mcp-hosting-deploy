# =============================================================================
# mcp.hosting -- AWS Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars to version control.
# =============================================================================

# Your domain (required) -- both root and *.domain must point to the server
domain = "mcp.example.com"

# mcp.hosting license key (required)
license_key = "mch_xxxxxxxxxxxxxxxxxxxx"

# PostgreSQL password (required) -- use a strong random password
db_password = "CHANGE_ME_to_a_strong_password"

# Cookie signing secret (required) -- random 32+ character string
cookie_secret = "CHANGE_ME_random_32_char_string_here"

# AWS region
# region = "us-east-1"

# EC2 instance type (t4g = ARM/Graviton)
# instance_type = "t4g.small"

# RDS instance class
# db_instance_class = "db.t4g.micro"

# ElastiCache node type
# cache_node_type = "cache.t4g.micro"

# Use the default VPC (true) or create a new one (false)
# use_default_vpc = true

# Name of an existing EC2 key pair for SSH access (leave empty to disable SSH)
# ssh_key_name = ""

# CIDR block allowed to SSH (restrict to your IP, e.g. "1.2.3.4/32")
# allowed_ssh_cidr = "0.0.0.0/0"

# Cloudflare API token for wildcard TLS certs (optional, needed for *.domain)
# cf_api_token = ""

# Extra tags for all resources
# tags = {
#   Environment = "production"
# }
