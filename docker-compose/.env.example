# =============================================================================
# mcp.hosting Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Domain & URL
# -----------------------------------------------------------------------------
# The base URL where your instance will be accessible.
# This must match your DNS setup. Include the protocol (https://).
BASE_URL=https://mcp.example.com

# Your root domain (used for wildcard TLS and routing).
# Caddy will serve *.DOMAIN and DOMAIN itself.
DOMAIN=mcp.example.com

# -----------------------------------------------------------------------------
# License Key (optional)
# -----------------------------------------------------------------------------
# Without a license key, you get the free tier:
#   - MCP server hosting
#   - Compliance & audit logging
#
# With a license key ($19/mo), you unlock:
#   - MCP proxy features (auth, rate limiting, routing)
#   - Priority support
#
# Get a license key at: https://mcp.hosting/pricing
MCP_HOSTING_LICENSE_KEY=

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=mcphosting
POSTGRES_PASSWORD=changeme-use-a-strong-password
POSTGRES_DB=mcphosting
DATABASE_URL=postgresql://mcphosting:changeme-use-a-strong-password@postgres:5432/mcphosting

# -----------------------------------------------------------------------------
# Redis (Valkey)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
# A random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
COOKIE_SECRET=changeme-generate-a-random-string

# -----------------------------------------------------------------------------
# Email (for magic link authentication)
# -----------------------------------------------------------------------------
# The "From" address for outgoing emails (magic links, notifications).
EMAIL_FROM=noreply@mcp.example.com

# AWS SES credentials for sending email.
# If not set, email sending will be disabled (useful for local dev).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
