# =============================================================================
# mcp.hosting Self-Hosted — Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Everything marked "Required" must be set before `docker compose up`.

# -----------------------------------------------------------------------------
# Domain & URL — REQUIRED
# -----------------------------------------------------------------------------
# Root domain where your instance will live. DO NOT include the protocol here.
# Point your domain's A record at this server before starting Caddy.
DOMAIN=mcp.example.com

# Full base URL, including https://. Used for absolute links in the dashboard
# and outbound emails (magic-link login).
BASE_URL=https://mcp.example.com

# -----------------------------------------------------------------------------
# License Key — OPTIONAL
# -----------------------------------------------------------------------------
# Without a license key, the instance runs as free-tier:
#   - mcph orchestrator + dashboard
#   - Up to 3 MCP servers per user
#   - Opt-in analytics with 7-day retention
#
# With a Team license key, paid features light up (unlimited servers,
# 30-day retention, Team admin controls, etc.). Subscribe to Team at
# https://mcp.hosting/pricing — the key appears in your hosted dashboard
# at Settings → Self-host license key. Format: mcph_sh_<hex>.
#
# MCP_HOSTING_LICENSE_KEY=mcph_sh_...

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
# POSTGRES_USER / POSTGRES_DB default to "mcphosting" if left blank; the
# password is required. Generate a strong one with: openssl rand -hex 24
POSTGRES_USER=mcphosting
POSTGRES_PASSWORD=changeme-use-openssl-rand-hex-24
POSTGRES_DB=mcphosting

# This DATABASE_URL must match the three values above and point at the
# "postgres" service (Docker Compose resolves this hostname automatically).
DATABASE_URL=postgresql://mcphosting:changeme-use-openssl-rand-hex-24@postgres:5432/mcphosting

# -----------------------------------------------------------------------------
# Redis / Valkey — defaults work with the bundled container
# -----------------------------------------------------------------------------
# The app reads REDIS_HOST + REDIS_PORT + optional REDIS_AUTH_TOKEN. The
# defaults point at the bundled valkey service on the compose network —
# override only if you're pointing at an external managed cache.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Session Security — REQUIRED
# -----------------------------------------------------------------------------
# Used to sign session cookies. Rotate if you suspect compromise —
# users get logged out on rotation. Generate with: openssl rand -hex 32
COOKIE_SECRET=changeme-use-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# GitHub OAuth — REQUIRED for dashboard sign-in
# -----------------------------------------------------------------------------
# Register a GitHub OAuth app at https://github.com/settings/developers
# and set the callback URL to https://your-domain.example/auth/github/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email / AWS SES — REQUIRED for login
# -----------------------------------------------------------------------------
# Magic-link authentication sends login codes via AWS SES. Without a verified
# SES sender identity and credentials, login will not work.
#
# Setup:
#   1. In the AWS console, verify EMAIL_FROM in SES (domain or address).
#   2. If your SES account is in sandbox, verify each recipient or request
#      production access for unrestricted sending.
#   3. Create an IAM user with ses:SendEmail + ses:SendRawEmail.
EMAIL_FROM=noreply@mcp.example.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
