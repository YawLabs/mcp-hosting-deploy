# =============================================================================
# mcp.hosting Self-Hosted — Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Every required variable below starts empty — the included validation
# step (`scripts/validate-env.sh`) refuses to start `docker compose up`
# until they're all set to real values. If you see a validation error
# mentioning a variable below, fill it in and re-run.
#
# Targeting a production deployment for a real team? Read
# docs/production-checklist.md FIRST — the bundled Postgres in this
# compose file is a development convenience, not a production database.

# -----------------------------------------------------------------------------
# Domain — REQUIRED
# -----------------------------------------------------------------------------
# Root domain where your instance will live. DO NOT include the protocol here.
# Point your domain's A record at this server before starting Caddy. This
# value is passed to the app as BASE_DOMAIN and used to build absolute
# links in the dashboard + outbound magic-link emails.
DOMAIN=

# -----------------------------------------------------------------------------
# License Key — REQUIRED
# -----------------------------------------------------------------------------
# Self-host requires an active Team subscription at mcp.hosting/pricing.
# Your license key + GHCR pull token are issued together in the hosted
# dashboard at Settings → Self-host. Without a valid license, the app
# refuses to boot.
#
# The license key is distinct from the GHCR pull token: this value goes
# in MCP_HOSTING_LICENSE_KEY inside the running container; the pull token
# is used once via `docker login ghcr.io -u self-host` before `docker
# compose up`. See docs/self-host-token.md.
#
# Format: mcph_sh_<hex>
MCP_HOSTING_LICENSE_KEY=

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
# POSTGRES_USER / POSTGRES_DB default to "mcphosting" if left blank.
# POSTGRES_PASSWORD is REQUIRED — generate a strong one:
#   openssl rand -hex 24
# Then also paste it into DATABASE_URL below (they must match).
POSTGRES_USER=mcphosting
POSTGRES_PASSWORD=
POSTGRES_DB=mcphosting

# DATABASE_URL must embed the password above and point at the
# "postgres" service (Docker Compose resolves this hostname).
# Example shape (with a real password substituted):
#   postgresql://mcphosting:<POSTGRES_PASSWORD>@postgres:5432/mcphosting
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis / Valkey — defaults work with the bundled container
# -----------------------------------------------------------------------------
# The app reads REDIS_HOST + REDIS_PORT + optional REDIS_AUTH_TOKEN. The
# bundled Compose defaults point at the local valkey service on the
# project network — override only if you're pointing at external managed
# cache (ElastiCache, Upstash, etc.). If you do override, also set
# REDIS_TLS=true since managed caches typically require it.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_AUTH_TOKEN=
# REDIS_TLS=false

# -----------------------------------------------------------------------------
# Session Security — REQUIRED
# -----------------------------------------------------------------------------
# Used to sign session cookies. Rotate if you suspect compromise —
# users get logged out on rotation. Generate with:
#   openssl rand -hex 32
COOKIE_SECRET=

# -----------------------------------------------------------------------------
# GitHub OAuth — REQUIRED for dashboard sign-in
# -----------------------------------------------------------------------------
# Register a GitHub OAuth app at https://github.com/settings/developers
# and set the callback URL to https://<your DOMAIN>/auth/github/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email / AWS SES — REQUIRED for login
# -----------------------------------------------------------------------------
# Magic-link authentication sends login codes via AWS SES. Without a verified
# SES sender identity and credentials, login will not work.
#
# Setup:
#   1. In the AWS console, verify EMAIL_FROM in SES (domain or address).
#   2. If your SES account is in sandbox, verify each recipient or request
#      production access for unrestricted sending.
#   3. Create an IAM user with ses:SendEmail + ses:SendRawEmail.
EMAIL_FROM=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Optional: OIDC SSO (Google, Okta, Azure AD, etc.)
# -----------------------------------------------------------------------------
# If set, the sign-in page shows a "Sign in with SSO" button that
# redirects to your OIDC provider. Leave empty to use magic-link email
# + (optionally) GitHub OAuth only.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
